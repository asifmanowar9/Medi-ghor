sion\":\"\",\"pv_purchase_price\":270,\"pv_campaign_tag_id\":0,\"pv_trending_score\":13.33,\"pv_created_at\":\"2025-07-20 17:38:51\",\"pv_created_by\":1794765,\"pv_modified_at\":\"2025-09-01 06:37:37\",\"pv_modified_by\":0,\"pv_deleted_at\":\"0000-00-00 00:00:00\",\"pv_deleted_by\":0,\"attachedFiles_pv_images\":\"\",\"pv_b2c_price\":400,\"pv_b2b_price\":400,\"pv_b2c_mrp\":550,\"pv_b2b_mrp\":550,\"pu_base_unit_multiplier\":1,\"pu_b2c_base_unit_multiplier\":1,\"pu_b2b_base_unit_multiplier\":1,\"pu_b2c_sales_unit_id\":88565,\"pu_b2b_sales_unit_id\":88565,\"pv_b2c_discount_percent\":27,\"pv_b2b_discount_percent\":27,\"pv_m_percentage\":32.5}],\"p_name\":\"OLO Dragon Tyrant Delay Condom 1 Pack - 10 Pcs\",\"p_strength\":\"\",\"p_form\":\"\",\"p_generic_id\":0,\"p_generic_name\":\"\",\"p_company_id\":0,\"p_manufacturer_id\":0,\"p_type\":\"sexual_wellness\",\"p_manufacturer\":\"\",\"p_product_keywords\":\"\",\"p_product_tags_title\":[\"sexual wellness new\",\"ITR_wellness\",\"sharodiya 2025\"],\"p_brand_id\":102095,\"p_brand\":\"olo\",\"id\":81985,\"is_antibiotics\":0,\"is_controlled\":0,\"p_id\":81773,\"p_rx_req\":0,\"p_medicine_id\":0,\"p_attribute\":[{\"vt_title\":\"Size\",\"vt_config\":[\"1's Pack \"]}],\"p_vendor_local_ids\":[{\"id\":480}],\"p_vendor_company_ids\":[{\"id\":761}],\"p_vendor_foreign_ids\":\"\",\"p_allow_sales\":1,\"p_description\":\"\u003cul\u003e\\n\u003cli\u003e\\n\u003cdiv\u003eA condom is a sheath that goes over your penis or inside your vagina during sex.\u003c/div\u003e\\n\u003c/li\u003e\\n\u003cli\u003e\\n\u003cdiv\u003eCondoms are the only type of contraception that can reduce the risk of sexually transmitted infections.\u003c/div\u003e\\n\u003c/li\u003e\\n\u003cli\u003e\\n\u003cdiv\u003eThey can be used for vaginal, anal or oral sex and with sex toys.\u003c/div\u003e\\n\u003c/li\u003e\\n\u003cli\u003e\\n\u003cdiv\u003eCondoms work well when they are used correctly, but they won’t work if they break, slip or are used incorrectly.\u003c/div\u003e\\n\u003c/li\u003e\\n\u003cli\u003e\\n\u003cdiv\u003eYou need to use a new condom each time you have sex.\u003c/div\u003e\\n\u003c/li\u003e\\n\u003c/ul\u003e\\n\u003cp\u003eCondoms act as a physical barrier. They prevent semen and other body fluids from passing between people during sex. This prevents the spread of STIs that may be found in body fluids. They also prevent pregnancy by stopping semen from getting to the uterus.\u003c/p\u003e\",\"p_meta_description\":\"\",\"p_yt_key\":\"\",\"p_yt_title\":\"\",\"p_allow_purchase\":0,\"p_variant_count\":1,\"p_active_status\":\"active\",\"p_cat_id\":0,\"p_cold\":0,\"p_is_not_allowed_outside_dhaka\":0,\"p_is_flash_sale\":0,\"p_weight\":0,\"p_product_category_id\":6308,\"p_version_change_status\":0,\"p_reference_id\":0,\"p_forward_reference_id\":0,\"p_backward_reference_id\":0,\"p_trending_score\":0,\"p_suggested_product_id\":0,\"p_is_simultaneous\":0,\"p_created_at\":\"2025-07-20 17:38:51\",\"p_created_by\":1794765,\"p_modified_at\":\"2025-07-21 17:33:42\",\"p_modified_by\":1599983,\"p_supervised_by\":0,\"p_deleted_at\":\"0000-00-00 00:00:00\",\"p_deleted_by\":0,\"p_supervised_at\":\"0000-00-00 00:00:00\",\"pu\":[{\"id\":88565,\"pu_id\":88565,\"pu_p_id\":81773,\"pu_multiplier\":1,\"pu_label\":\"10 pcs\",\"pu_is_base\":1,\"pu_is_b2b_sales_enabled\":1,\"pu_is_b2c_sales_enabled\":1,\"pu_is_default_purchase_unit\":1,\"pu_is_b2b_sales_unit\":1,\"pu_is_b2c_sales_unit\":1,\"pu_is_purchase_enabled\":1,\"pu_created_at\":\"2025-07-20 17:38:51\",\"pu_created_by\":1794765,\"pu_modified_at\":\"2025-07-20 17:38:51\",\"pu_modified_by\":1794765,\"pu_deleted_at\":\"0000-00-00 00:00:00\",\"pu_deleted_by\":0}],\"attachedFiles_p_images\":[{\"title\":\"Untitled-2 (41).png\",\"src\":\"https://cdn2.arogga.com/eyJidWNrZXQiOiJhcm9nZ2EiLCJrZXkiOiJQcm9kdWN0LXBfaW1hZ2VzXC84MTc3M1wvODE3NzMtVW50aXRsZWQtMi00MS05azBkcGsucG5nIiwiZWRpdHMiOnsicmVzaXplIjp7IndpZHRoIjozMDAsImhlaWdodCI6MzAwLCJmaXQiOiJvdXRzaWRlIn19fQ==\"}],\"p_product_tags\":[\"sexual_wellness_ne