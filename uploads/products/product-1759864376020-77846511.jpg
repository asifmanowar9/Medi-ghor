Doll Acne Solution Serum Foam Cleanser\",\"p_strength\":\"\",\"p_form\":\"\",\"p_generic_id\":0,\"p_generic_name\":\"\",\"p_company_id\":0,\"p_manufacturer_id\":0,\"p_type\":\"beauty\",\"p_manufacturer\":\"\",\"p_product_keywords\":\"\",\"p_product_tags_title\":[\"authentic-beauty\",\"b2b_sales\",\"Flash Sale\"],\"p_brand_id\":100453,\"p_brand\":\"Cathy Doll\",\"id\":53509,\"is_antibiotics\":0,\"is_controlled\":0,\"p_id\":53509,\"p_rx_req\":0,\"p_medicine_id\":53509,\"p_attribute\":\"\",\"p_vendor_local_ids\":[{\"id\":480},{\"id\":507},{\"id\":508}],\"p_vendor_company_ids\":[{\"id\":756}],\"p_vendor_foreign_ids\":\"\",\"p_allow_sales\":1,\"p_description\":\"\u003cp\u003e\u003cstrong\u003eKey features\u003cbr\u003e\u003c/strong\u003e\u003c/p\u003e\\n\u003cul\u003e\\n\u003cli\u003eInfused with tea tree serum ideal for sensitive skin.\u003c/li\u003e\\n\u003cli\u003eAids in oil control and reduces acne outbreak.\u003c/li\u003e\\n\u003cli\u003eBrightens your skin and reduces dark spot when when used continuously.\u003c/li\u003e\\n\u003cli\u003e\u003cspan class=\\\"a-list-item\\\"\u003eThis face wash helps your skin control oil and reduces acne outbreak also helps brighten your skin and reduces dark spot.\u003cbr\u003e\u003c/span\u003e\u003c/li\u003e\\n\u003cli\u003e\u003cspan class=\\\"a-list-item\\\"\u003eThis face wash helps your skin control oil and reduces acne outbreak.\u003cbr\u003e\u003c/span\u003e\u003c/li\u003e\\n\u003cli\u003e\u003cspan class=\\\"a-list-item\\\"\u003eIt helps brighten your skin and reduces dark spot.\u003c/span\u003e\u003c/li\u003e\\n\u003cli\u003e\u003cspan class=\\\"a-list-item\\\"\u003eIt is dermatologist tested.\u003c/span\u003e\u003c/li\u003e\\n\u003c/ul\u003e\\n\u003cp\u003e\u003cstrong\u003eHow to use\u003cbr\u003e\u003c/strong\u003e\u003c/p\u003e\\n\u003cul\u003e\\n\u003cli\u003eSqueeze out a small amount onto your palm and gently massage palms together until foam forms.\u003c/li\u003e\\n\u003cli\u003eMassage the foam in a gentle circular motion all over your face, before washing off the product with water.\u003c/li\u003e\\n\u003c/ul\u003e\",\"p_meta_description\":\"\",\"p_yt_key\":\"\",\"p_yt_title\":\"\",\"p_allow_purchase\":1,\"p_variant_count\":1,\"p_active_status\":\"active\",\"p_cat_id\":0,\"p_cold\":0,\"p_is_not_allowed_outside_dhaka\":0,\"p_is_flash_sale\":1,\"p_weight\":0,\"p_product_category_id\":7014,\"p_version_change_status\":0,\"p_reference_id\":0,\"p_forward_reference_id\":0,\"p_backward_reference_id\":0,\"p_trending_score\":25.77,\"p_suggested_product_id\":0,\"p_is_simultaneous\":1,\"p_created_at\":\"0000-00-00 00:00:00\",\"p_created_by\":614071,\"p_modified_at\":\"2025-09-15 21:17:25\",\"p_modified_by\":51236,\"p_supervised_by\":0,\"p_deleted_at\":\"0000-00-00 00:00:00\",\"p_deleted_by\":0,\"p_supervised_at\":\"0000-00-00 00:00:00\",\"pu\":[{\"id\":51769,\"pu_id\":51769,\"pu_p_id\":53509,\"pu_multiplier\":1,\"pu_label\":\"100ml tube\",\"pu_is_base\":1,\"pu_is_b2b_sales_enabled\":1,\"pu_is_b2c_sales_enabled\":1,\"pu_is_default_purchase_unit\":1,\"pu_is_b2b_sales_unit\":1,\"pu_is_b2c_sales_unit\":1,\"pu_is_purchase_enabled\":1,\"pu_created_at\":\"0000-00-00 00:00:00\",\"pu_created_by\":0,\"pu_modified_at\":\"0000-00-00 00:00:00\",\"pu_modified_by\":0,\"pu_deleted_at\":\"0000-00-00 00:00:00\",\"pu_deleted_by\":0}],\"attachedFiles_p_images\":[{\"title\":\"Cathe Doll Acne Solution copy.jpg\",\"src\":\"https://cdn2.arogga.com/eyJidWNrZXQiOiJhcm9nZ2EiLCJrZXkiOiJQcm9kdWN0LXBfaW1hZ2VzXC81MzUwOVwvNTM1MDktQ2F0aGUtRG9sbC1BY25lLVNvbHV0aW9uLWNvcHktbGs5NTF3LmpwZWciLCJlZGl0cyI6eyJyZXNpemUiOnsid2lkdGgiOjMwMCwiaGVpZ2h0IjozMDAsImZpdCI6Im91dHNpZGUifX19\"}],\"p_product_tags\":[\"authentic_beauty\",\"b2b_sales\",\"flash_sale\"],\"p_product_internal_tags\":[],\"p_product_internal_tags_title\":[],\"p_is_reviewable\":true,\"POSTER\":\"\",\"haveImage\":1,\"productCountViewed\":5905,\"productCountOrdered\":231,\"productCountWishlist\":26},{\"pv\":[{\"pv_id\":75475,\"pu_base_unit_label\":\"Stick\",\"pu_b2c_s