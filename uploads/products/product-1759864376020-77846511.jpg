,\"static/chunks/13b76428-a7244c9fbdb657d6.js\",\"4506\",\"static/chunks/f97e080b-3aee8d4c41a24bc0.js\",\"8087\",\"static/chunks/0e762574-422c52947d838c20.js\",\"9933\",\"static/chunks/c857e369-6b7882c82639329a.js\",\"6711\",\"static/chunks/8e1d74a4-02cb20f83a3e6ae7.js\",\"3873\",\"stati"])</script><script>self.__next_f.push([1,"c/chunks/3d47b92a-06c763406dac668e.js\",\"9204\",\"static/chunks/94730671-d7f6da9d5c08e104.js\",\"3380\",\"static/chunks/479ba886-7ee697dedd3d9651.js\",\"8465\",\"static/chunks/f4898fe8-2fafa268534dde59.js\",\"4935\",\"static/chunks/e37a0b60-f30f95a88bd2236e.js\",\"75\",\"static/chunks/75-adff0b8d1a588c61.js\",\"2523\",\"static/chunks/2523-b8a16afa40b71121.js\",\"3063\",\"static/chunks/3063-69e8dc158635c111.js\",\"138\",\"static/chunks/138-55d24101a262c4d0.js\",\"6820\",\"static/chunks/6820-8005f5345805effd.js\",\"3500\",\"static/chunks/3500-1ab0378428fa009b.js\",\"4029\",\"static/chunks/4029-222fe38a806f8444.js\",\"7400\",\"static/chunks/7400-7660faf5b9bf2f7c.js\",\"2499\",\"static/chunks/2499-24bb704cc4dc27f8.js\",\"7116\",\"static/chunks/7116-0a3d7c4634474257.js\",\"7586\",\"static/chunks/7586-bbdce932315bf17b.js\",\"3948\",\"static/chunks/3948-b706a98ad24b7f45.js\",\"9937\",\"static/chunks/9937-46a31db4e4b51860.js\",\"5113\",\"static/chunks/5113-85e76a363db2081c.js\",\"5894\",\"static/chunks/5894-e74d0cf2af75c221.js\",\"5558\",\"static/chunks/app/(user-portal)/(Ecommerce)/page-6abcca9d39e05369.js\"],\"default\"]\n2a:T1659,"])</script><script>self.__next_f.push([1,"\u003ch2\u003e\u003cstrong\u003eProduct Description: Ultra HCG One Step Pregnancy Test Kit\u003c/strong\u003e\u003c/h2\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eProduct Name:\u003c/strong\u003e Ultra HCG One Step Pregnancy Test Kit (Midstream or Dipstick)\u003cbr /\u003e\u003cstrong\u003eBrand:\u003c/strong\u003e (This could be a store brand, e.g., \"First Response,\" \"Clearblue,\" \"ClinicalGuard,\" or a generic manufacturer. The description below is for a generic, high-quality kit.)\u003cbr /\u003e\u003cstrong\u003eQuantity:\u003c/strong\u003e Commonly available in 1, 3, 5, or multi-pack kits.\u003c/p\u003e\n\u003chr /\u003e\n\u003ch4\u003e\u003cstrong\u003eOverview\u003c/strong\u003e\u003c/h4\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003eThe Ultra HCG One Step Pregnancy Test Kit is a rapid, over-the-counter, qualitative immunoassay designed for the early detection of pregnancy. It delivers clear, accurate results in the privacy of your home within minutes by detecting the presence of Human Chorionic Gonadotropin (hCG) in urine.\u003c/p\u003e\n\u003ch4\u003e\u003cstrong\u003eKey Features \u0026amp; Benefits\u003c/strong\u003e\u003c/h4\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eHigh Accuracy:\u003c/strong\u003e Boasts over \u003cstrong\u003e99% accuracy\u003c/strong\u003e in detecting pregnancy from the day of the expected period when used as directed.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eEarly Detection:\u003c/strong\u003e Sensitive enough to detect low levels of hCG, allowing for potential detection up to \u003cstrong\u003e5 days before your missed period\u003c/strong\u003e.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eFast \u0026amp; Clear Results:\u003c/strong\u003e Get easy-to-read results in just \u003cstrong\u003e3-5 minutes\u003c/strong\u003e. Results are displayed as clear lines: one line for negative, two distinct lines for positive.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eSimple One-Step Procedure:\u003c/strong\u003e The midstream design allows for direct use in the urine stream, eliminating the need for cups and droppers. (Some versions may be dip-stick style).\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eHygienic \u0026amp; Discreet:\u003c/strong\u003e Individually sealed, moisture-proof foil pouches ensure sterility and privacy for each test.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eClinically Proven:\u003c/strong\u003e The technology is based on the same type of assay used in many hospitals and clinics.\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch4\u003e\u003cstrong\u003eTechnical Specifications\u003c/strong\u003e\u003c/h4\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eTest Type:\u003c/strong\u003e Lateral Flow Immunochromatographic Assay\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eSample Type:\u003c/strong\u003e Urine\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eSensitivity:\u003c/strong\u003e Typically \u003cstrong\u003e10 mIU/mL\u003c/strong\u003e to \u003cstrong\u003e25 mIU/mL\u003c/strong\u003e. This high sensitivity is what allows for early detection. (mIU/mL = milli-International Units per Milliliter)\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eResult Time:\u003c/strong\u003e 3-5 minutes (Do not read after 10 minutes)\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eStorage:\u003c/strong\u003e Store in a cool, dry place at room temperature (2°C - 30°C / 36°F - 86°F). Do not freeze.\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch4\u003e\u003cstrong\u003eWhat’s in the Box?\u003c/strong\u003e\u003c/h4\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003eEach kit contains:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eSealed Foil Pouches:\u003c/strong\u003e Each pouch contains one individually wrapped test device.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eTest Devices:\u003c/strong\u003e Midstream sticks or dip strips with an absorbent tip and a results window.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eInstructions for Use:\u003c/strong\u003e A detailed, step-by-step leaflet in multiple languages.\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cem\u003e(Note: Silica gel desiccant may be included in the box to control moisture, with a \"Do Not Eat\" warning).\u003c/em\u003e\u003c/p\u003e\n\u003ch4\u003e\u003cstrong\u003eIntended Use\u003c/strong\u003e\u003c/h4\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003eThis kit is intended for the qualitative detection of human Chorionic Gonadotropin (hCG) in urine to aid in the early detection of pregnancy. It is for \u003cstrong\u003ein vitro diagnostic use only\u003c/strong\u003e (external use).\u003c/p\u003e\n\u003ch4\u003e\u003cstrong\u003eDirections for Use (Summary)\u003c/strong\u003e\u003c/h4\u003e\n\u003col start=\"1\"\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eWhen to Test:\u003c/strong\u003e Test from the day of your missed period. For earliest detection, use first-morning urine.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eRemove:\u003c/strong\u003e Take the test stick out of its sealed foil pouch.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eApply Urine:\u003c/strong\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eMidstream:\u003c/strong\u003e Place the absorbent tip in your urine stream for 5-10 seconds.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eDip:\u003c/strong\u003e Collect urine in a clean cup and dip the tip for 5-10 seconds.\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eWait:\u003c/strong\u003e Lay the test flat and wait 3-5 minutes for the results to appear.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eRead:\u003c/strong\u003e Interpret the results. \u003cstrong\u003eDo not read after 10 minutes.\u003c/strong\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch4\u003e\u003cstrong\u003eResult Interpretation\u003c/strong\u003e\u003c/h4\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003ePositive (Pregnant):\u003c/strong\u003e Two distinct pink (or blue) lines appear. One in the Control region (C) and one in the Test region (T). \u003cstrong\u003eAny faint line in the T region is considered positive.\u003c/strong\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eNegative (Not Pregnant):\u003c/strong\u003e Only one pink (or blue) line appears in the Control region (C). No line appears in the Test region (T).\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp class=\"ds-markdown-paragraph\"\u003e\u003cstrong\u003eInvalid:\u003c/strong\u003e No control line appears. The test must be discarded and repeated with a new device.\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e"])</script><script>self.__next_f.push([1,"2b:T4a2,\u003cp\u003e\u003cbr /\u003e\u003cbr /\u003e\u003cstrong\u003eKey Specifications\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eSpecial Features: \u003cbr /\u003eReal chicken meat \u003cbr /\u003e100% natural \u003cbr /\u003ewithout contamination \u003cbr /\u003eWith delicious flavor, \u003cbr /\u003esweet smell, the chicken jerky is a good inviting food \u003cbr /\u003efor you dogs when \u003cbr /\u003ethey have no appetite  \u003cbr /\u003ekeeping fit, a healthy training reward for \u003cbr /\u003eall size dogs  \u003cbr /\u003eA good nutritional food for tired, sick, pregnant, \u003cbr /\u003eand postpartum dogs  \u003cbr /\u003eAfter being specially processed, the dry meat jerky has a good firm texture  \u003cbr /\u003eIt can help dogs to massage their teeth and gums, \u003cbr /\u003ereduce tartar, prevent tooth decay, and bad breath  \u003cbr /\u003eIt will also help maintain your dogs healthy fitness      \u003cbr /\u003eRecommendations for feeding: as a chew snack for between meals. Always provide an adequate supply of fresh drinking water.\u003c/p\u003e\n\u003cp\u003eIngredients: \u003c/p\u003e\n\u003cdiv\u003e\n\u003cdiv\u003eVegetable protein, glycerin, starch, beer yeast, \u003cbr /\u003evegetable oil, tea polyhenol, dietary fiber, beef extractive, EC permitted colorants.\n\u003cdiv\u003e\u003cbr /\u003eNutritional Analysis: \n\u003cdiv\u003eCrude protein 30.0%  \u003cbr /\u003eCrude fat 0.5%  Fiber 1.0% Ash 5.0%  Moisture 16.0%\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e2c:T54e,\u003cp\u003e\u003cspan style=\"color: rgb(35,111,161);\"\u003e\u003cstrong\u003eSmartCure Premium Thumb Spica Splint\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003eThe SmartCure Thumb spica splint is a user-friendly device created to immobilize the thumb in a functionally neutral position of abduction. It provides support to the CMC joint while also immobilizing the MCP joint of the thumb, without restricting overall hand movement.\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eProduct Details:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eModel:\u003c/strong\u003e LHSG-TSSC\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eMaterial:\u003c/strong\u003e Fabrics, cotton, metal, aluminum, and velcro\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSize: \u003c/strong\u003eUniversal (Free size) | 5.0 to 9.5 in | 12.50 to 23.80 cm |\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eSize Measurement:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eMeasure circumference evenly around the wris"])</script><script>self.__next_f.push([1,"t joint.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eUsing Conditions:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eLigament strains\u003c/li\u003e\n\u003cli\u003eThumb injury\u003c/li\u003e\n\u003cli\u003eTenosynovitis\u003c/li\u003e\n\u003cli\u003eCarpal tunnel\u003c/li\u003e\n\u003cli\u003eThumb arthritis\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eUser Benefits:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eFits both right \u0026amp; left hand\u003c/li\u003e\n\u003cli\u003eOne size fits both men \u0026amp; women\u003c/li\u003e\n\u003cli\u003eRemovable aluminum splint\u003c/li\u003e\n\u003cli\u003eBreathable fabric\u003c/li\u003e\n\u003cli\u003eErgonomic design\u003c/li\u003e\n\u003c/ul\u003e2d:T807,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003eNeutrogena T/Gel 2-in-1 Anti-Dandruff Shampoo and Conditioner is a specialized hair care product designed to combat dandruff while leaving hair soft and shiny. This formula combines the cleansing power of a shampoo with the nourishing benefits of a conditioner, making it convenient for daily use.\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e \u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003e\u003cbr /\u003eKey Features:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eActive Ingredients:\u003c/strong\u003e Contains salicylic acid and piroctone olamine, which help fight dandruff by breaking down the build-up of dead skin cells on the scalp.\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eFragrance:\u003c/strong\u003e Infused with a gentle melon and jasmine scent, providing a refreshing hair-washing experience.\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eDermatologist-Tested:\u003c/strong\u003e Developed with dermatologists to ensure its efficacy in relieving scalp itching and flaking associated with dandruff.\u003c/span\u003e\u003c/p\u003e\n\u003cbr /\u003e\n\u003cp\u003e \u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eUsage Instructions:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003col\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003eWet hair thoroughly.\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003eApply a liberal amount of the product and massage into the scalp.\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003eRinse thoroughly.\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003eRepeat if necessary.\u003cbr /\u003e\u003cbr /\u003e\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003cp\u003e\u003cspan style=\"font-size:12pt;font-family:helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eMade in Greece\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e"])</script><script>self.__next_f.push([1,"2e:T13dc,"])</script><script>self.__next_f.push([1,"\u003cdiv class=\"card__section \"\u003e\n\u003cdiv class=\"rte text--pull\"\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eEnhance your skin complexion effectively and get a fairer and brighter face by using this instafair melanin control and skin lightening from Lotus Professional. This kit effectively brings in skin lightening that lightens skin tone and evens skin complexion effectively. Make your skin brighter and fairer by making use of this instafair skin lightening kit that has combined effects of controlling melanin in your skin. This instafair kit comprises of instafair mulberry whitening masque, skin whitening pill mask along with skin whitening concentrate. The mulberry masque is enriched with extracts of mulberry, rice bran, cucumber, orange peel, almond oil and lettuce. All the ingredients of the masque play a significant role in rejuvenating your skin by effectively controlling and preventing skin darkening. The skin whitening complex contains extracts of avocado, lavender, milk enzymes and grape seed which makes your skin fairer by delivering a high amount of actives.\u003c/span\u003e\u003c/p\u003e\n\u003cul class=\"a-unordered-list a-vertical a-spacing-mini\"\u003e\n\u003cli class=\"a-spacing-mini\"\u003e\n\u003cp\u003e\u003cspan class=\"a-list-item\" style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eEnhance your skin complexion effectively and get a fairer and brighter face\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli class=\"a-spacing-mini\"\u003e\n\u003cp\u003e\u003cspan class=\"a-list-item\" style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eThe skin whitening complex contains extracts of avocado, lavender, milk enzymes and grape seed which makes your skin fairer by delivering a high amount of actives\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli class=\"a-spacing-mini\"\u003e\n\u003cp\u003e\u003cspan class=\"a-list-item\" style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eThe mulberry masque is enriched with extracts of mulberry, rice bran, cucumber, orange peel, almond oil and lettuce. All the ingredients of the masque play a significant role in rejuvenating your skin by effectively controlling and preventing skin darkening\u003c/span\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u003cstrong\u003eKit Content:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e1 x Instafair Skin Whitening Complex(5ml)\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e1 x Instafair Mulberry Whitening Masque(60gm)\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e6 x Instafair Skin Whitening Concentrate(5ml)\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e6 x Pill Masks\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eProduct Benefit:\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eWhitening, Hydrating, Lightening, Radiant Skin, Soothing, Anti-ageing, Brightening \u0026amp; Freshning\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u003cstrong\u003eHow to Use:\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003eAfter the basic CETOM (Cleanse-Exfoliate-Tone-Moisturise) with HYDRAVITALS or PURAVITALS (depending upon the skin type)\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003eInduction of INSTAFAIR Skin Whitening Complex with the help of ultrasonic.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003eMassage with HYDRAVITALS jojoba stimulating massage cream or puravitals\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003eCinnamon Energising Massage Gel.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003eApply Instafair Skin Mulberry whitening masque.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cbr\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u003cstrong\u003eSteps to Use The Pill Mask:\u003c/strong\u003e\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eStep 1\u003c/strong\u003e : Take about 100 ml water in a tumbler. Drop one pill mask in water.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eStep 2\u003c/strong\u003e : Pill mask will open up. Drain out the water taking care that opened pill mask remains in the tumbler.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eStep 3 \u003c/strong\u003e: Break the neck of one ampoule and empty the 'Concentrate' over the pill mask, taking care that whole of pill mask is drenched in 'Concentrate'.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eStep 4\u003c/strong\u003e : Spread the pill mask (drenched in Concentrate over the face). After 10-15 minutes remove the pill mask.\u003cbr\u003e\u003cbr\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003e\u003cspan style=\"font-size: 12pt; font-family: helvetica, arial, sans-serif;\"\u003eMade in India\u003c/span\u003e\u003c/strong\u003e\u003c/p\u003e\n\u003c/div\u003e\n\u003c/div\u003e"])</script><script>self.__next_f.push([1,"2f:T524,\u003cp\u003e\u003cspan style=\"font-family:helvetica, arial, sans-serif;font-size:12pt;\"\u003eAchieve a flawless, radiant complexion with Gigi Rose Blemish BB Cream. This lightweight formula blends seamlessly to conceal blemishes, even skin tone, and provide a natural, dewy finish. Infused with nourishing ingredients, it helps improve skin’s texture over time. Experience the perfect balance of coverage and skincare with Gigi Rose.\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-family:helvetica, arial, sans-serif;font-size:12pt;\"\u003eDesigned for all skin types, GIGI ROSE BB Cream offers broad-spectrum SPF protection to shield your skin from harmful UV rays, while its buildable coverage allows you to customize your look, whether you’re going for a natural finish or more coverage for a polished look. Enriched with antioxidants and soothing agents, it helps maintain skin’s hydration throughout the day, leaving your complexion looking fresh and dewy.\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-family:helvetica, arial, sans-serif;font-size:12pt;\"\u003eIdeal for those who want a multi-tasking product that simplifies their beauty routine, GIGI ROSE BB Cream provides the perfect balance of skincare benefits and makeup performance. Achieve smooth, glowing skin with every application—experience the luxury of premium-quality, everyday beauty.\u003c/span\u003e\u003c/p\u003e30:Tde3,"])</script><script>self.__next_f.push([1,"\u003cp\u003eThe Yuwell Blood Glucose Strips (50 pieces) are designed to be used with Yuwell blood glucose meters for accurate and convenient blood sugar level testing. Here is a detailed description of these test strips:\u003c/p\u003e\n\u003ch3\u003eKey Features:\u003c/h3\u003e\n\u003col\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eHigh Accuracy\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eMade with advanced enzyme technology to ensure precise and consistent blood glucose readings.\u003c/li\u003e\n\u003cli\u003eCalibrated to work specifically with Yuwell glucose meters, reducing the risk of inaccurate measurements.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eEasy to Use\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eSimple design allows for easy handling and application of blood samples.\u003c/li\u003e\n\u003cli\u003eClear indicators on the strip guide the user on where to place the blood sample.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eSmall Blood Sample Requirement\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eRequires only a tiny blood sample (usually around 0.5 microliters), making the testing process less invasive and more comfortable.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eFast Results\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eDelivers quick results, typically within 5 seconds, enabling prompt monitoring and decision-making.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eAuto Coding\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eStrips are automatically recognized by compatible Yuwell meters, eliminating the need for manual coding and simplifying the testing process.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eConvenient Packaging\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eComes in a pack of 50 strips, providing an ample supply for regular monitoring.\u003c/li\u003e\n\u003cli\u003eStrips are individually sealed or stored in a protective vial to maintain their integrity and effectiveness.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch3\u003eTechnical Specifications:\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eSample Type\u003c/strong\u003e: Capillary whole blood.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eEnzyme\u003c/strong\u003e: Glucose oxidase technology for accurate glucose detection.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eMeasurement Range\u003c/strong\u003e: Typically from 20 mg/dL to 600 mg/dL (1.1 mmol/L to 33.3 mmol/L), depending on the compatible meter’s range.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eOperating Conditions\u003c/strong\u003e: Best used within a temperature range of approximately 10°C to 40°C (50°F to 104°F) and humidity range of 10% to 90%.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3\u003ePackage Contents:\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e50 Yuwell Blood Glucose Strips.\u003c/li\u003e\n\u003cli\u003eInstructions for use.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3\u003eUsage Instructions:\u003c/h3\u003e\n\u003col\u003e\n\u003cli\u003e\u003cstrong\u003ePreparation\u003c/strong\u003e:\n\u003cul\u003e\n\u003cli\u003eWash and dry hands thoroughly before testing.\u003c/li\u003e\n\u003cli\u003eEnsure your Yuwell glucose meter is ready and properly set up.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eInserting the Strip\u003c/strong\u003e:\n\u003cul\u003e\n\u003cli\u003eTake a strip from the vial and immediately close the vial to protect the remaining strips.\u003c/li\u003e\n\u003cli\u003eInsert the strip into the meter as per the device instructions.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eLancing\u003c/strong\u003e:\n\u003cul\u003e\n\u003cli\u003eUse a lancing device to obtain a blood sample from your fingertip or another approved site.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eApplying Blood Sample\u003c/strong\u003e:\n\u003cul\u003e\n\u003cli\u003eApply the blood sample to the designated area on the strip.\u003c/li\u003e\n\u003cli\u003eEnsure that the blood fully covers the test area for an accurate reading.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eReading the Result\u003c/strong\u003e:\n\u003cul\u003e\n\u003cli\u003eWait for the meter to display the glucose level.\u003c/li\u003e\n\u003cli\u003eRecord the result if needed or review it in the meter’s memory.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch3\u003eStorage Instructions:\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eStore the strips in a cool, dry place away from direct sunlight and humidity.\u003c/li\u003e\n\u003cli\u003eKeep the strips in their original vial or packaging until ready to use.\u003c/li\u003e\n\u003cli\u003eAvoid touching the test area of the strip to maintain its accuracy.\u003c/li\u003e\n\u003c/ul\u003e"])</script><script>self.__next_f.push([1,"31:T177e,"])</script><script>self.__next_f.push([1,"\u003cdiv class=\"product-details__description\"\u003e\n\u003cdiv\u003e\n\u003cdiv class=\"product-details__description\"\u003e\n\u003cp class=\"product-details__description\" style=\"text-align: justify;\"\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eDeveloped with dermatologists, CeraVe Hydrating Toner, with ceramides, hyaluronic acid, and niacinamide, helps restore the skin\u0026rsquo;s natural protective barrier for improved hydration, and helps visibly smooth and calm skin. The formula is non-comedogenic, alcohol-free, oil-free, astringent-free, and fragrance-free and helps to remove leftover residue while helping maintain the skins moisture barrier. This lightweight, leave-on formula can be used as the last step in a cleansing routine to remove residue, so you can start your skincare routine with a clean canvas.\u003c/span\u003e\u003c/p\u003e\n\u003ch3 class=\"product-details__description\" style=\"text-align: justify;\"\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eCountry of Origin Poland\u003c/span\u003e\u003c/h3\u003e\n\u003ch2 class=\"default\" style=\"text-align: justify;\"\u003e\u003cspan style=\"font-size: 14pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eProduct Description\u003c/strong\u003e\u003c/span\u003e\u003c/h2\u003e\n\u003cp class=\"default\" style=\"text-align: justify;\"\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eDeveloped with dermatologists, CeraVe Hydrating Toner hydrates and smooths the skin while removing any remaining makeup and impurities. The pH balanced, lightweight toner is also alcohol-free, fragrance-free, oil-free, and non-comedogenic so it will not clog your pores. The non-astringent and non-drying formula contains hyaluronic acid, niacinamide, and three essential ceramides (1, 3, 6-6-II) and leaves skin feeling balanced, soothed, soft, and clean.\u003c/span\u003e\u003c/p\u003e\n\u003cdiv class=\"a-section a-spacing-small\" style=\"text-align: justify;\"\u003e\n\u003cp\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Paraben-free\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Fragrance-free\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Alcohol-free\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Oil-free\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Non-comedogenic\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Allergy-tested\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Gentle, non-irritating formula\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull; Suitable for normal-to-dry skin, and sensitive skin\u003c/span\u003e\u003c/p\u003e\n\u003cp\u003e\u003cspan style=\"font-size: 14pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003e\u003cspan class=\"a-text-bold\"\u003eKey Ingredients:\u003c/span\u003e\u003c/strong\u003e\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull;\u0026nbsp;\u003cspan class=\"a-text-bold\"\u003e\u003cu\u003eCeramides\u003c/u\u003e\u003c/span\u003e: Essential for healthy skin, ceramides help restore and maintain the skin\u0026rsquo;s natural barrier\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull;\u0026nbsp;\u003cspan class=\"a-text-bold\"\u003e\u003cu\u003eHyaluronic Acid\u003c/u\u003e\u003c/span\u003e: This ingredient attracts hydration to the skin\u0026rsquo;s surface and helps the skin retain moisture\u003c/span\u003e\u003cbr\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003e\u0026bull;\u0026nbsp;\u003cspan class=\"a-text-bold\"\u003e\u003cu\u003eNiacinamide\u003c/u\u003e\u003c/span\u003e: Helps repair a compromised skin barrier while improving the appearance of the skin\u003c/span\u003e\u003c/p\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003cdiv class=\"product-details__accordions\"\u003e\n\u003cdiv class=\"accordion\" style=\"text-align: justify;\"\u003e\n\u003cdiv class=\"accordion__title\"\u003e\n\u003cdiv class=\"icon-trigger\"\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif;\"\u003e\u003cspan style=\"font-size: 12pt;\"\u003e\u0026nbsp;\u003c/span\u003e\u003cstrong style=\"font-size: 14pt;\"\u003eBENEFITS\u003c/strong\u003e\u003c/span\u003e\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003cdiv class=\"accordion\"\u003e\n\u003cdiv class=\"accordion__title\" style=\"text-align: justify;\"\u003e\n\u003cdiv class=\"icon-trigger icon-trigger--turn\"\u003e\n\u003cul style=\"text-align: justify;\"\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eCeramides: Help maintain the protective skin barrier\u003c/span\u003e\u003c/li\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eHyaluronic acid: Helps retain skin\u0026rsquo;s natural moisture\u003c/span\u003e\u003c/li\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eNiacinamide: Helps calm the skin\u003c/span\u003e\u003c/li\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eSuitable for normal to dry skin, and sensitive skin\u003c/span\u003e\u003c/li\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eNon-comedogenic, fragrance-free, alcohol-free, oil-free, allergy-tested, and pH-balanced toner for face\u003c/span\u003e\u003c/li\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eFacial toner developed with dermatologists\u003c/span\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003cdiv class=\"accordion__content\"\u003e\n\u003cdiv class=\"accordion__title\" style=\"text-align: justify;\"\u003e\n\u003cp\u003e\u003cspan style=\"font-size: 14pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eHOW TO USE\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eSaturate a cotton pad with the Hydrating Toner\u003c/span\u003e\u003c/li\u003e\n\u003cli\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eGently wipe the pad over your skin until it is completely free of any residue left after cleansing\u003c/span\u003e\u003c/li\u003e\n\u003cli style=\"text-align: justify;\"\u003e\u003cspan style=\"font-family: helvetica, arial, sans-serif; font-size: 12pt;\"\u003eUse after cleansing in the morning and evening to help moisturize and maintain the skin barrier\u003c/span\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/div\u003e\n\u003cdiv class=\"accordion__content\"\u003e\n\u003cp style=\"text-align: justify;\"\u003e\u003cspan style=\"font-size: 14pt; font-family: helvetica, arial, sans-serif;\"\u003e\u003cstrong\u003eMade in Poland\u003c/strong\u003e\u003c/span\u003e\u003c/p\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\u003c/div\u003e"])</script><script>self.__next_f.push([1,"32:T935,"])</script><script>self.__next_f.push([1,"\u003ch3\u003e\u003cstrong\u003eFingertip Pulse Oximeter – OxyWatch (ChoiceMMed)\u003c/strong\u003e\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003eReliable | Accurate | Easy to Use\u003c/strong\u003e\u003c/p\u003e\n\u003chr /\u003e\n\u003cp\u003e\u003cstrong\u003eProduct Overview:\u003c/strong\u003e\u003cbr /\u003eThe \u003cstrong\u003eOxyWatch Fingertip Pulse Oximeter by ChoiceMMed\u003c/strong\u003e is a user-friendly, compact medical device that provides \u003cstrong\u003equick and accurate readings of blood oxygen saturation (SpO₂)\u003c/strong\u003e and \u003cstrong\u003epulse rate\u003c/strong\u003e. Ideal for \u003cstrong\u003ehome monitoring, sports, and clinical environments\u003c/strong\u003e, this device ensures consistent performance with minimal effort.\u003c/p\u003e\n\u003chr /\u003e\n\u003ch3\u003e✅ \u003cstrong\u003eKey Features:\u003c/strong\u003e\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eAccurate SpO₂ \u0026amp; Pulse Rate Readings\u003c/strong\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eBright LED Display\u003c/strong\u003e – Clear and easy to read\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eSimple One-Button Operation\u003c/strong\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eAuto Shut-Off\u003c/strong\u003e – Conserves battery when not in use\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eLightweight \u0026amp; Portable\u003c/strong\u003e – Perfect for everyday use\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eLow Battery Indicator\u003c/strong\u003e – Stay informed and ready\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003chr /\u003e\n\u003ch3\u003e📊 \u003cstrong\u003eTechnical Specifications:\u003c/strong\u003e\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eModel:\u003c/strong\u003e OxyWatch (ChoiceMMed)\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eSpO₂ Range:\u003c/strong\u003e 70% – 100%\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003ePulse Rate Range:\u003c/strong\u003e 30 – 235 bpm\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eDisplay:\u003c/strong\u003e LED\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003ePower Supply:\u003c/strong\u003e 2 × AAA Batteries\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eUsage:\u003c/strong\u003e Suitable for both adults and children\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eWeight:\u003c/strong\u003e Approx. 50g (including batteries)\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003chr /\u003e\n\u003ch3\u003e📦 \u003cstrong\u003ePackage Includes:\u003c/strong\u003e\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003e1 × Fingertip Pulse Oximeter\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e1 × Lanyard\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e1 × User Manual\u003cbr /\u003e\u003cem\u003e(Batteries may or may not be included depending on packaging)\u003c/em\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003chr /\u003e\n\u003cp\u003e\u003cstrong\u003eUse For:\u003c/strong\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003eRespiratory monitoring\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003eAthletes and fitness monitoring\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003eAltitude performance tracking\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003eHome and clinical health assessments\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003chr /\u003e\n\u003cp\u003e\u003cstrong\u003eBrand:\u003c/strong\u003e ChoiceMMed\u003cbr /\u003e\u003cstrong\u003eModel Name:\u003c/strong\u003e OxyWatch\u003cbr /\u003e\u003cstrong\u003eCountry of Origin:\u003c/strong\u003e China\u003cbr /\u003e\u003cstrong\u003eCertifications:\u003c/strong\u003e CE / FDA Compliant\u003c/p\u003e"])</script><script>self.__next_f.push([1,"33:Tfb6,"])</script><script>self.__next_f.push([1,"\u003cp\u003